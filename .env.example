# Required for AI-generated flashcards, explanations, and image/frame captioning.
ANTHROPIC_API_KEY=

# Optional overrides — sensible defaults are used if omitted.
# CLAUDE_TEXT_MODEL=claude-sonnet-5
# CLAUDE_VISION_MODEL=claude-sonnet-5

# Local Whisper transcription settings (tiny/base/small/medium/large-v3).
# Larger models are more accurate but slower and use more RAM.
# WHISPER_MODEL_SIZE=small
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Video keyframe sampling.
# VIDEO_FRAME_INTERVAL_SECONDS=15
# VIDEO_MAX_FRAMES=12

# ANKI_APP_HOST=127.0.0.1
# ANKI_APP_PORT=8000
