# Required for AI-generated flashcards, explanations, and image/frame captioning.
ANTHROPIC_API_KEY=

# Optional overrides — sensible defaults are used if omitted.
# CLAUDE_TEXT_MODEL=claude-sonnet-5
# CLAUDE_VISION_MODEL=claude-sonnet-5

# Local Whisper transcription settings (tiny/base/small/medium/large-v3).
# Larger models are more accurate but slower and use more RAM.
# WHISPER_MODEL_SIZE=small
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Video keyframe sampling.
# VIDEO_FRAME_INTERVAL_SECONDS=15
# VIDEO_MAX_FRAMES=12

# ANKI_APP_HOST=127.0.0.1
# ANKI_APP_PORT=8000

# Require a login (strongly recommended once ANKI_APP_HOST is reachable from
# other devices, e.g. self-hosting with Tailscale, or any public deployment).
# APP_USERNAME=
# APP_PASSWORD=

# AnkiConnect (local Anki desktop add-on). Only reachable if this backend
# runs on the same machine as Anki desktop. Defaults match AnkiConnect's own
# defaults, so you usually don't need to set these.
# ANKICONNECT_URL=http://127.0.0.1:8765
# ANKICONNECT_API_KEY=

# Daily Notes: what time of day (24h "HH:MM", server local time) to
# automatically card whatever's new since the last run.
# DAILY_NOTES_CARD_TIME=23:59
